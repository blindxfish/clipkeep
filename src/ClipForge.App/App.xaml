<Application x:Class="ClipForge.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ClipForge.App.Converters">
    <Application.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:StringToVisibilityConverter x:Key="StrToVis"/>
        <conv:PathToImageConverter x:Key="PathToImage"/>
    </Application.Resources>
</Application>
