<Window x:Class="ClipForge.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipForge Settings" Height="620" Width="560"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/ClipForge.ico"
        Background="#141416">
    <Window.Resources>
        <SolidColorBrush x:Key="Fg" Color="#EDEDED"/>
        <SolidColorBrush x:Key="Muted" Color="#8A8A8E"/>
        <SolidColorBrush x:Key="Panel" Color="#1E1E20"/>
        <SolidColorBrush x:Key="Accent" Color="#E23B3B"/>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Header">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="General" Style="{StaticResource Header}"/>
                <CheckBox Content="Launch on Windows startup" IsChecked="{Binding LaunchOnStartup}"/>
                <CheckBox Content="Start minimized to tray" IsChecked="{Binding StartMinimized}"/>
                <CheckBox Content="Show notifications" IsChecked="{Binding ShowNotifications}"/>
                <CheckBox Content="Confirm before deleting items" IsChecked="{Binding ConfirmBeforeDelete}"/>

                <TextBlock Text="Clipboard Monitoring" Style="{StaticResource Header}"/>
                <CheckBox Content="Enable monitoring" IsChecked="{Binding EnableMonitoring}"/>
                <CheckBox Content="Monitor text" IsChecked="{Binding MonitorText}"/>
                <CheckBox Content="Monitor images (coming soon)" IsChecked="{Binding MonitorImages}" IsEnabled="False"/>
                <CheckBox Content="Monitor files (coming soon)" IsChecked="{Binding MonitorFiles}" IsEnabled="False"/>
                <CheckBox Content="Monitor HTML / rich text (coming soon)" IsChecked="{Binding MonitorHtml}" IsEnabled="False"/>

                <TextBlock Text="Privacy" Style="{StaticResource Header}"/>
                <CheckBox Content="Never save sensitive content (cards, keys, tokens)"
                          IsChecked="{Binding DoNotSaveSensitive}"/>
                <TextBlock Text="Excluded applications" Foreground="{StaticResource Muted}" Margin="0,10,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewExcludedApp, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource Panel}" Foreground="{StaticResource Fg}"
                             BorderThickness="0" Padding="6,4" VerticalContentAlignment="Center"
                             ToolTip="Process or app name, e.g. bitwarden.exe"/>
                    <Button Grid.Column="1" Content="Add" Margin="8,0,0,0" Padding="12,4"
                            Command="{Binding AddExcludedAppCommand}"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding ExcludedApps}" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding}" Foreground="{StaticResource Fg}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Remove" Padding="8,2"
                                        Command="{Binding DataContext.RemoveExcludedAppCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Storage" Style="{StaticResource Header}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Retention:" Foreground="{StaticResource Fg}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="160" ItemsSource="{Binding RetentionOptions}"
                              SelectedItem="{Binding Retention}"/>
                </StackPanel>
                <TextBlock Text="Favorites are never removed by retention cleanup."
                           Foreground="{StaticResource Muted}" FontSize="11" Margin="0,6,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Padding="16,6" Margin="0,0,8,0"/>
            <Button Content="Save" Padding="16,6" Command="{Binding SaveCommand}"
                    Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
