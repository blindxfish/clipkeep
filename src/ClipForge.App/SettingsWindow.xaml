<Window x:Class="ClipForge.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="ClipForge Settings" Height="660" Width="580"
        WindowStyle="None" ResizeMode="CanResize" AllowsTransparency="False"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Assets/ClipForge.ico"
        Background="{StaticResource WindowBg}" Foreground="{StaticResource Fg}"
        FontFamily="Segoe UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="Header" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,20,0,8"/>
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Margin" Value="0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid Grid.Row="0" Background="{StaticResource WindowBg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                           Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                <TextBlock Text="Settings" Foreground="{StaticResource Fg}" FontSize="14"
                           FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="TitleCloseButton" Style="{StaticResource CaptionCloseButton}"
                    Content="&#xE8BB;" Click="CloseWindow_Click"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,0,22,0">
            <StackPanel>
                <TextBlock Text="General" Style="{StaticResource Header}" Margin="0,8,0,8"/>
                <CheckBox Content="Launch on Windows startup" IsChecked="{Binding LaunchOnStartup}"/>
                <CheckBox Content="Start minimized to tray" IsChecked="{Binding StartMinimized}"/>
                <CheckBox Content="Show notifications" IsChecked="{Binding ShowNotifications}"/>
                <CheckBox Content="Confirm before deleting items" IsChecked="{Binding ConfirmBeforeDelete}"/>

                <TextBlock Text="Clipboard Monitoring" Style="{StaticResource Header}"/>
                <CheckBox Content="Enable monitoring" IsChecked="{Binding EnableMonitoring}"/>
                <CheckBox Content="Monitor text" IsChecked="{Binding MonitorText}"/>
                <CheckBox Content="Monitor images (coming soon)" IsChecked="{Binding MonitorImages}" IsEnabled="False"/>
                <CheckBox Content="Monitor files (coming soon)" IsChecked="{Binding MonitorFiles}" IsEnabled="False"/>
                <CheckBox Content="Monitor HTML / rich text (coming soon)" IsChecked="{Binding MonitorHtml}" IsEnabled="False"/>

                <TextBlock Text="Privacy" Style="{StaticResource Header}"/>
                <CheckBox Content="Never save sensitive content (cards, keys, tokens)"
                          IsChecked="{Binding DoNotSaveSensitive}"/>
                <TextBlock Text="Excluded applications" Foreground="{StaticResource Muted}" Margin="0,12,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                             Text="{Binding NewExcludedApp, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Process or app name, e.g. bitwarden.exe"/>
                    <Button Grid.Column="1" Content="Add" Style="{StaticResource PillButton}" Margin="8,0,0,0"
                            Command="{Binding AddExcludedAppCommand}"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding ExcludedApps}" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Card}" CornerRadius="7" Padding="10,6" Margin="0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding}" Foreground="{StaticResource Fg}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Remove" Style="{StaticResource PillButton}" Padding="10,4"
                                            Command="{Binding DataContext.RemoveExcludedAppCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Storage" Style="{StaticResource Header}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Retention:" Foreground="{StaticResource Fg}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Width="180" Style="{StaticResource DarkCombo}"
                              ItemsSource="{Binding RetentionOptions}" SelectedItem="{Binding Retention}"/>
                </StackPanel>
                <TextBlock Text="Favorites are never removed by retention cleanup."
                           Foreground="{StaticResource Muted}" FontSize="11" Margin="0,8,0,0"/>

                <TextBlock Text="About" Style="{StaticResource Header}"/>
                <TextBlock Foreground="{StaticResource Fg}" TextWrapping="Wrap">
                    <Run Text="ClipForge"/><Run x:Name="VersionRun" Foreground="{StaticResource Muted}"/>
                </TextBlock>
                <TextBlock Foreground="{StaticResource Fg}" TextWrapping="Wrap" Margin="0,6,0,0">
                    <Run Text="Made by"/>
                    <Hyperlink NavigateUri="https://nixonsolutions.org/" RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{StaticResource Accent}" TextDecorations="None">Nixon Software Solutions</Hyperlink><Run Text="."/>
                </TextBlock>
                <TextBlock Text="Free and open source." Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,16">
                    <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/blindxfish/clipforge" RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{StaticResource Accent}" TextDecorations="None">
                            <InlineUIContainer BaselineAlignment="Center">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource Accent}"/>
                            </InlineUIContainer><Run Text=" GitHub"/>
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Text="   &#x2022;   " Foreground="{StaticResource Muted}"/>
                    <TextBlock>
                        <Hyperlink NavigateUri="https://nixonsolutions.org/" RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{StaticResource Accent}" TextDecorations="None">nixonsolutions.org</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource Panel}" Padding="22,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource PillButton}"
                        Padding="18,8" Margin="0,0,8,0"/>
                <Button Content="Save" Style="{StaticResource AccentPillButton}" Padding="20,8"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
