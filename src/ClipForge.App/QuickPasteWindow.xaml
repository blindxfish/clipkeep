<Window x:Class="ClipForge.App.QuickPasteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True" AllowsTransparency="True" Background="Transparent"
        SizeToContent="Manual" Width="460" Height="380"
        WindowStartupLocation="Manual">
    <Border Background="#1E1E20" CornerRadius="8" BorderBrush="#E23B3B" BorderThickness="1">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox" Grid.Row="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="14" Padding="8,6" Margin="0,0,0,8"
                     Background="#141416" Foreground="#EDEDED" BorderThickness="0"
                     VerticalContentAlignment="Center"/>

            <ListBox x:Name="ResultsList" Grid.Row="1"
                     ItemsSource="{Binding Entries}"
                     SelectedItem="{Binding SelectedEntry}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="6,4">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Type}" FontSize="10"
                                               Foreground="#E23B3B" FontWeight="SemiBold"/>
                                    <TextBlock Text="  ★" Foreground="Gold" FontSize="10"
                                               Visibility="{Binding Favorite, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Content}" Foreground="#EDEDED"
                                           TextTrimming="CharacterEllipsis" MaxHeight="34"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
