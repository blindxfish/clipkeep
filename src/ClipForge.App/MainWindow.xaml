<Window x:Class="ClipForge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipForge" Height="620" Width="960"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/ClipForge.ico"
        Background="#141416">
    <Window.Resources>
        <SolidColorBrush x:Key="Fg" Color="#EDEDED"/>
        <SolidColorBrush x:Key="Muted" Color="#8A8A8E"/>
        <SolidColorBrush x:Key="Panel" Color="#1E1E20"/>
        <SolidColorBrush x:Key="Accent" Color="#E23B3B"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/Assets/logo.png" Width="28" Height="28"/>
                <TextBlock Text="ClipForge" Foreground="{StaticResource Fg}" FontSize="16"
                           FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBox Grid.Column="1"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                     FontSize="15" Padding="8,6" Background="{StaticResource Panel}"
                     Foreground="{StaticResource Fg}" BorderThickness="0"
                     VerticalContentAlignment="Center"
                     ToolTip="Search clipboard history"/>
            <CheckBox Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center"
                      Content="Pause" Foreground="{StaticResource Muted}"
                      IsChecked="{Binding IsPaused}"/>
        </Grid>

        <!-- Body: sidebar + list + details -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left sidebar -->
            <DockPanel Grid.Column="0">
                <Button DockPanel.Dock="Bottom" Content="⚙  Settings" HorizontalContentAlignment="Left"
                        Padding="10,8" Margin="0,8,0,0" BorderThickness="0"
                        Background="{StaticResource Panel}" Foreground="{StaticResource Fg}"
                        Command="{Binding OpenSettingsCommand}"/>
                <ListBox ItemsSource="{Binding Filters}" SelectedItem="{Binding SelectedFilter}"
                         Background="{StaticResource Panel}" BorderThickness="0"
                         Foreground="{StaticResource Fg}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" Padding="6,8" Foreground="{StaticResource Fg}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <ListBox Grid.Column="2" x:Name="EntriesList"
                     ItemsSource="{Binding Entries}"
                     SelectedItem="{Binding SelectedEntry}"
                     Background="{StaticResource Panel}" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,6" Margin="0,1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Type}" FontSize="11"
                                               Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
                                    <TextBlock Text="  •  " Foreground="{StaticResource Muted}"/>
                                    <TextBlock Text="{Binding SourceApp}" FontSize="11"
                                               Foreground="{StaticResource Muted}"/>
                                    <TextBlock Text="  ★" Foreground="Gold" FontSize="11"
                                               Visibility="{Binding Favorite, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Content}" Foreground="{StaticResource Fg}"
                                           TextTrimming="CharacterEllipsis" MaxHeight="40"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Details panel -->
            <Border Grid.Column="4" Background="{StaticResource Panel}" Padding="14">
                <Grid>
                    <TextBlock Text="Select an entry" Foreground="{StaticResource Muted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVis}}"/>
                    <StackPanel DataContext="{Binding SelectedEntry}">
                        <TextBlock Text="{Binding Type}" Foreground="{StaticResource Accent}"
                                   FontWeight="Bold" FontSize="13"/>
                        <ScrollViewer MaxHeight="260" Margin="0,8" VerticalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding Content, Mode=OneWay}" IsReadOnly="True"
                                     TextWrapping="Wrap" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource Fg}"/>
                        </ScrollViewer>
                        <TextBlock Foreground="{StaticResource Muted}" FontSize="12">
                            <Run Text="Source: "/><Run Text="{Binding SourceApp}"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Muted}" FontSize="12">
                            <Run Text="Window: "/><Run Text="{Binding WindowTitle}"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Muted}" FontSize="12">
                            <Run Text="Copied "/><Run Text="{Binding CopyCount}"/><Run Text=" time(s)"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Muted}" FontSize="12">
                            <Run Text="Last: "/><Run Text="{Binding LastCopiedAt}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="Copy" Padding="12,4" Margin="0,0,8,0"
                                    Command="{Binding DataContext.CopySelectedCommand, ElementName=EntriesList}"/>
                            <Button Content="★ Favorite" Padding="12,4" Margin="0,0,8,0"
                                    Command="{Binding DataContext.ToggleFavoriteCommand, ElementName=EntriesList}"/>
                            <Button Content="Delete" Padding="12,4"
                                    Command="{Binding DataContext.DeleteSelectedCommand, ElementName=EntriesList}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
